    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Rust (cargo run)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build"
                ],
                "filter": {
                    "name": "onvif-ip-camera-mock",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "debug",
                "RTSP_URL": "rtsp://127.0.0.1:8554/cam1"
            }
        }
    ]
}